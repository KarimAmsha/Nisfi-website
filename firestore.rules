rules_version = '2';

// Nisfi Firestore security rules — Unit 0.5 baseline.
// Starts from DEFAULT DENY (master spec Section 11). Shared predicates and the
// core invariants are established here; per-collection rules and the full
// emulator test matrix (Section 11.4) are expanded in each feature unit
// (e.g. profiles in Unit 2.1). Custom claims — not the mirrored Firestore
// field — are authoritative for roles.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isSelf(u) {
      return signedIn() && uid() == u;
    }
    function role() {
      return signedIn() && request.auth.token.keys().hasAny(['role']) ? request.auth.token.role : 'user';
    }
    function isStaff() {
      return role() in ['moderator', 'admin', 'superAdmin'];
    }
    function isAdmin() {
      return role() in ['admin', 'superAdmin'];
    }
    function isSuper() {
      return role() == 'superAdmin';
    }
    function isActive() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && get(/databases/$(database)/documents/users/$(uid())).data.status == 'active';
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    // Owner-editable public-profile keys (keep in sync with EDITABLE_PROFILE_KEYS
    // in @nisfi/shared). System/moderation/photo fields are never client-written.
    function profileUpdateKeys() {
      return [
        'displayName', 'gender', 'birthDate', 'country', 'city', 'about',
        'maritalStatus', 'children', 'religiousness', 'education', 'occupation',
        'marriageTimeline', 'languages', 'visibility', 'answers', 'updatedAt'
      ];
    }
    function profileCreateKeys() {
      return [
        'displayName', 'gender', 'birthDate', 'country', 'city', 'about',
        'maritalStatus', 'children', 'religiousness', 'education', 'occupation',
        'marriageTimeline', 'languages', 'visibility', 'answers', 'updatedAt', 'createdAt'
      ];
    }

    // users/{uid}: owner + staff read; no client create/delete; owner may update
    // only allow-listed preference/locale fields. Role/status/counters are
    // server-only (Cloud Functions with admin privileges bypass these rules).
    match /users/{u} {
      allow read: if isSelf(u) || isStaff();
      allow create, delete: if false;
      allow update: if isSelf(u)
        && changedKeys().hasOnly(['locale', 'preferences', 'updatedAt']);

      match /devices/{deviceId} {
        allow read: if isSelf(u);
        allow write: if isSelf(u);
      }
      match /private/{doc} {
        allow read: if isSelf(u) || isStaff();
        allow write: if isSelf(u);
      }
    }

    // profiles/{uid}: owner + staff always; a non-owner active member may read
    // only an eligible/visible profile — visible AND server-verified (Unit 3.1,
    // master spec Section 11.4). Gender/block/match exclusions are applied by the
    // discovery query and Cloud Functions, not per-doc rules; block-based read
    // denial arrives with the block foundation (Unit 3.6). Writes stay
    // field-locked to the owner-editable public keys; system/moderation/photo
    // fields and client-set timestamps are rejected, and createdAt/updatedAt must
    // be the server time (Unit 2.1).
    match /profiles/{u} {
      allow read: if isSelf(u)
        || isStaff()
        || (isActive()
            && resource.data.visibility == 'visible'
            && resource.data.verificationStatus == 'verified');
      allow create: if isSelf(u)
        && request.resource.data.keys().hasOnly(profileCreateKeys())
        && request.resource.data.displayName is string
        && request.resource.data.gender in ['male', 'female']
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isSelf(u)
        && changedKeys().hasOnly(profileUpdateKeys())
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;

      // Private, sensitive sub-document: owner writes; owner + staff read.
      match /private/{doc} {
        allow read: if isSelf(u) || isStaff();
        allow write: if isSelf(u);
      }
    }

    // verificationRequests: owner + staff read; active owner may create a
    // strictly-shaped pending request; decisions are server-only.
    match /verificationRequests/{id} {
      allow read: if isStaff() || (signedIn() && resource.data.uid == uid());
      allow create: if isActive()
        && request.resource.data.uid == uid()
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // reports/{id}: an active member may create a strictly-shaped `open` report
    // about someone else; staff read all; transitions/sanctions are server-only
    // (no client update/delete). Master spec Sections F8, 10.7, 11.4.
    match /reports/{id} {
      allow read: if isStaff();
      allow create: if isActive()
        && request.resource.data.reporterUid == uid()
        && request.resource.data.targetUid != uid()
        && request.resource.data.status == 'open'
        && request.resource.data.handledBy == null
        && request.resource.data.resolutionNote == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.targetType in ['profile', 'message', 'request']
        && request.resource.data.reason in
             ['fake_profile', 'inappropriate_photos', 'harassment', 'scam', 'underage', 'other']
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 500;
      allow update, delete: if false;
    }

    // questionBank/{id}: admin-managed compatibility questions the onboarding
    // wizard renders. Any signed-in member reads (they need the questions to
    // build a profile); ALL writes are server-only (admin via the content CF +
    // audit; clients never write content). Master spec Sections 6.1, 10.9, 11.4.
    match /questionBank/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    // connectionRequests: the two participants + staff may read; ALL writes are
    // server-only (CF6 sendConnectionRequest / CF7 respond/withdraw via the Admin
    // SDK, which bypasses these rules). Clients never create or transition a
    // request — this is where dedupe, cooldown, and the pending/daily limits are
    // atomically enforced (master spec Sections F5, 11.4, 12).
    match /connectionRequests/{id} {
      allow read: if isStaff()
        || (signedIn() && (resource.data.fromUid == uid() || resource.data.toUid == uid()));
      allow create, update, delete: if false;
    }

    // matches/{pairKey}: the two participants may read; ALL writes are server-
    // only (the accepted-request transaction / CF7 via the Admin SDK creates the
    // match — clients can never create matches; reveal/unread/close are also
    // server-managed). Messages are handled in their own unit (4.2), still denied
    // here (master spec Sections F6, 10.5, 11.4).
    match /matches/{pairKey} {
      allow read: if signedIn() && request.auth.uid in resource.data.uids;
      allow create, update, delete: if false;

      // messages/{id}: an active participant of the match may create an exact
      // text-message document; the sender may soft-delete only their own message
      // within 15 minutes (flip `deleted` to true). No hard delete, and clients
      // never write moderation fields (Functions flag) or preview/unread (on the
      // match doc). Master spec Sections F6, 10.5, 11.4.
      match /messages/{id} {
        function matchDoc() {
          return get(/databases/$(database)/documents/matches/$(pairKey)).data;
        }
        function isMatchMember() {
          return signedIn() && uid() in matchDoc().uids;
        }
        allow read: if isMatchMember();
        allow create: if isActive()
          && isMatchMember()
          && matchDoc().status == 'active'
          && request.resource.data.keys().hasOnly(
               ['senderUid', 'text', 'deleted', 'moderation', 'createdAt'])
          && request.resource.data.senderUid == uid()
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 1000
          && request.resource.data.deleted == false
          && request.resource.data.moderation.flagged == false
          && request.resource.data.createdAt == request.time;
        allow update: if isMatchMember()
          && resource.data.senderUid == uid()
          && changedKeys().hasOnly(['deleted'])
          && request.resource.data.deleted == true
          && request.time < resource.data.createdAt + duration.value(15, 'm');
        allow delete: if false;
      }
    }

    // blocks/{uid}/blocked/{targetUid}: owner reads their own block list; ALL
    // writes are server-only (CF10 blockUser/unblockUser via the Admin SDK,
    // which also closes any active match). Instant, unilateral, silent — the
    // target is never told (master spec Sections F6, 11.4).
    match /blocks/{u}/blocked/{targetUid} {
      allow read: if isSelf(u);
      allow write: if false;
    }

    // notifications: owner reads; owner may only flip `read`; no create/delete.
    match /notifications/{u}/items/{id} {
      allow read: if isSelf(u);
      allow update: if isSelf(u) && changedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // auditLogs: superAdmin read only; append is Functions-only.
    match /auditLogs/{id} {
      allow read: if isSuper();
      allow write: if false;
    }

    // Everything not explicitly designed and tested yet is denied to clients.
    // (Cloud Functions use the Admin SDK and are not subject to these rules.)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
