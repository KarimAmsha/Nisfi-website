# Environment variable names only. Keep all values empty.
# Copy to .env.local only when an approved future unit requires local configuration.

NEXT_PUBLIC_APP_ENV=
NEXT_PUBLIC_APP_URL=

# Set to "true" to run the web app against the local Firebase emulators
# (no real project keys needed — development/preview per directive O-001).
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase App Check (reCAPTCHA v3 site key). Optional in local/dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Server-only secrets — never commit; provide via environment secrets.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
