# ─────────────────────────────────────────────────────────────────────────────
# Nisfi — web environment template. Copy to `.env.local` (git-ignored) for local
# real-project runs, or set these in your host (e.g. Vercel) for production.
# NEVER commit real values. See docs/PRODUCTION_SETUP.md for where each comes from.
# ─────────────────────────────────────────────────────────────────────────────

# Emulator mode: leave "true" for local dev without real keys; set "false"
# (or remove) in production so the real Firebase config below is used.
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true

# Firebase Web app config (Project settings → General → Your apps → Web app).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# FCM Web Push certificate key pair (Project settings → Cloud Messaging → Web configuration).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase App Check — reCAPTCHA v3 site key (App Check → Web app → reCAPTCHA v3).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Canonical public origin (used for metadata/sitemap/robots). e.g. https://nisfi.app
NEXT_PUBLIC_SITE_URL=

# Cloudinary (Dashboard → Product environment cloud name). Public value.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
